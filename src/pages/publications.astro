---
import MainLayout from "../layouts/mainLayout.astro";
import PublicationCard from "../components/publicationCard.astro";
import Heading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";

import publications from "../data/publications.json";

const sortedPublications = [...publications].sort(
  (a, b) => Number(b.year) - Number(a.year)
);
---

<MainLayout>
  <PageSection>
    <Heading level="h1" size="xl"> Publications </Heading>

    <!-- Search -->
    <div class="mb-6">
      <input
        type="text"
        id="searchInput"
        placeholder="Search by title, authors, or year..."
        class="w-full px-4 py-2 border rounded-md"
      />
    </div>

    <!-- Publications Grid -->
    <div id="pubGrid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        sortedPublications.map((pub) => (
          <div
            class="pub-item"
            data-search={`${pub.title} ${pub.authors.join(" ")} ${pub.year}`.toLowerCase()}
          >
            <PublicationCard publication={pub} />
          </div>
        ))
      }
    </div>

    <!-- No Results -->
    <p id="noResults" class="hidden text-center mt-6 text-muted">
      No publications found.
    </p>
  </PageSection>
</MainLayout>

<script>
  // Search Logic
  document.addEventListener("DOMContentLoaded", () => {
    const searchInput = document.getElementById(
      "searchInput",
    ) as HTMLInputElement;
    const items = document.querySelectorAll(
      ".pub-item",
    ) as NodeListOf<HTMLElement>;
    const noResults = document.getElementById("noResults") as HTMLElement;

    function filterPublications() {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      items.forEach((item) => {
        const text = item.getAttribute("data-search") as string;

        if (!query || text.includes(query)) {
          item.style.display = "block";
          visibleCount++;
        } else {
          item.style.display = "none";
        }
      });

      noResults.style.display = visibleCount ? "none" : "block";
    }

    searchInput.addEventListener("input", filterPublications);
  });

  // Copy Citation Logic
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest(".copy-btn");
    if (!btn) return;

    const text = btn.getAttribute("data-citation") as string;

    navigator.clipboard.writeText(text).then(() => {
      const original = btn.textContent;
      btn.textContent = "Copied!";

      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    });
  });
</script>
