---
import GradientLayout from "../layouts/gradientLayout.astro";
import Heading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";
import Button from "../components/button.astro";
import Link from "../components/link.astro";
import Divider from "../components/divider.astro";
import Card from "../components/card.astro";
---

<GradientLayout>
  <PageSection>
    <!-- Heading -->
    <div class="text-center">
      <Heading level="h1" size="xl">
        Scientific discovery by video game players
      </Heading>

      <div class="mt-5 mb-5 flex justify-center">
        <Divider class="bg-[var(--color-accent)]" />
      </div>
    </div>

    <!-- Content Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 md:gap-6 lg:gap-6">
      <Card>
        <div class="text-center px-2">
          <div class="mb-5 flex justify-center">
            <img
              src="images/icons/research.svg"
              alt="research"
              class="h-13 w-13"
            />
          </div>
          <p class="leading-relaxed">
            Our research group is interested in engaging the public to help us
            solve difficult scientific problems. We harness the collective
            brainpower of humans worldwide to tackle critical problems posed in
            computational biology.
          </p>
        </div>
      </Card>

      <Card>
        <div class="text-center px-2">
          <div class="mb-5 flex justify-center">
            <img src="images/icons/game.svg" alt="game" class="h-13 w-13" />
          </div>
          <p class="leading-relaxed">
            Our research group is interested in engaging the public to help us
            solve difficult scientific problems. We harness the collective
            brainpower of humans worldwide to tackle critical problems posed in
            computational biology.
          </p>
        </div>
      </Card>

      <Card>
        <div class="text-center px-2">
          <div class="mb-5 flex justify-center">
            <img
              src="images/icons/hci.svg"
              alt="human computer collab"
              class="h-13 w-13"
            />
          </div>
          <p class="leading-relaxed">
            Our research group is interested in engaging the public to help us
            solve difficult scientific problems. We harness the collective
            brainpower of humans worldwide to tackle critical problems posed in
            computational biology.
          </p>
        </div>
      </Card>
    </div>

    <!-- CTA Buttons -->
    <div
      class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6"
    >
      <Link href="/research">
        <Button variant="primary"> Explore Our Research </Button>
      </Link>

      <Link href="/contact">
        <Button variant="secondary"> Contact Us </Button>
      </Link>
    </div>
  </PageSection>
</GradientLayout>
