---
import MainLayout from "../layouts/mainLayout.astro";
import Divider from "../components/divider.astro";
import Card from "../components/card.astro";
import PageHeading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";
---

<MainLayout>

  <PageSection class="space-y-4">

    <PageHeading title="CV" />

    <!-- Profile Card -->
    <Card>
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">

        <!-- Name -->
        <div>
          <h1 class="heading-md tracking-widest uppercase">
            Firas Khatib, Ph.D.
          </h1>

          <p class="mt-3 text-md">
            Associate Professor
          </p>

          <p class="mt-1 text-md">
            University of Massachusetts Dartmouth
          </p>
        </div>

        <!-- Image -->
        <div class="flex justify-center md:justify-end">
          <img
            src="/images/fkhatib.jpg"
            alt="Firas Khatib"
            class="w-32 h-32 md:w-40 md:h-40 rounded-full object-cover shadow-md"
          />
        </div>

      </div>
    </Card>

    <!-- Education -->
    <Card>
      <h2 class="heading-md">
        Education
      </h2>

      <Divider />

      <ul class="mt-4 space-y-4">
        <li>
          Ph.D. in Bioinformatics (2002 - 2008), University of California, Santa Cruz, CA
        </li>
        <li>
          B.A. in Applied Mathematics (1997 - 2001), University of California, Berkeley, CA
        </li>
      </ul>
    </Card>

    <!-- Experience -->
    <Card>
      <h2 class="heading-md">
        Research and Professional Experience
      </h2>

      <Divider />

      <ul class="mt-4 space-y-4">
        <li>
          <strong>2008 - 2013:</strong> Postdoctoral fellow. Dr. David Baker; Department of Biochemistry, University of Washington, Seattle, WA.
        </li>
        <li>
          <strong>2005 - 2008:</strong> Graduate Student Researcher. Dr. Kevin Karplus; Department of Biomolecular Engineering, University of California, Santa Cruz, CA.
        </li>
        <li>
          <strong>2002 - 2005:</strong> Graduate Student Researcher. Dr. Carol A. Rohl; Department of Biomolecular Engineering, University of California, Santa Cruz, CA.
        </li>
        <li>
          <strong>2001:</strong> Undergraduate research. Dr. Lior Pachter; Department of Mathematics, University of California, Berkeley, CA.
        </li>
      </ul>
    </Card>

  </section>

</PageSection>