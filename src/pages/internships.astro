---
import MainLayout from "../layouts/mainLayout.astro";
import Heading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";
import Button from "../components/button.astro";
import Link from "../components/link.astro";
import Divider from "../components/divider.astro";
import AppImage from "../components/appImage.astro";
---

<MainLayout>
  <PageSection>
    <!-- Content Cards -->
    <div class="flex flex-col items-center text-center">
        <div class="text-center">
          <Heading level="h1" size="xl"> Summer Internships </Heading>
          <div class="flex justify-center">
            <Divider class="bg-[var(--color-secondary)]" />
          </div>
        </div>

        <div class="px-2 space-y-6">
          <div>
            <p class="text-lg font-semibold">
              Join Our Research Community
            </p>

            <p class="text-lg md:text-xl leading-relaxed text-neutral-700 max-w-2xl mx-auto">
              Explore opportunities in computational biology, citizen science,
              and collaborative research.
            </p>
          </div>

          <div>
            <Link
              href="https://rosettacommons.org/education/reu/"
              external
              newTab
            >
              <Button variant="primary"> Apply Now &rarr; </Button>
            </Link>
          </div>

          <div class="flex justify-center">
            <AppImage
              src="/images/internship.png"
              alt="internship"
              class="w-2/3 sm:w-5 md:w-2/3 xl:w-4/5 max-w-md drop-shadow-lg"
            />
          </div>
        </div>
    </div>
  </PageSection>
</MainLayout>
