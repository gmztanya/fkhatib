---
import MainLayout from "../layouts/mainLayout.astro";
import VideoCard from "../components/videoCard.astro";
import Link from "../components/link.astro";
import PageHeading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";

import media from "../data/media.json";

type MediaItem = (typeof media.otherMedia)[number];
type MediaGroup = {
  source: string;
  items: MediaItem[];
};

const featuredVideos = media.featuredVideos;
const moreVideos = media.otherVideos;

const otherMediaGrouped = Object.values(
  media.otherMedia.reduce<Record<string, MediaGroup>>(
    (groupedBySource, item) => {
      if (!groupedBySource[item.source]) {
        groupedBySource[item.source] = {
          source: item.source,
          items: []
        };
      }

      groupedBySource[item.source].items.push(item);
      return groupedBySource;
    },
    {}
  )
);
---

<MainLayout>

  <PageSection class="space-y-4">

    <PageHeading title="Media" />

    <!-- Featured Videos Section -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Featured Videos</h2>

      <div class="relative">

        <div class="embla overflow-hidden">
          <div class="embla__container flex gap-4 m-4">
            {
              featuredVideos.map((video) => (
                <div class="embla__slide embla-slide flex-[0_0_85%] sm:flex-[0_0_75%] md:flex-[0_0_65%] lg:flex-[0_0_55%]">
                  <VideoCard video={video} />
                </div>
              ))
            }
          </div>
        </div>

        <!-- Controls -->
        <button id="prevBtn" class="carousel-btn left-4">‹</button>
        <button id="nextBtn" class="carousel-btn right-4">›</button>
      </div>
    </section>

    <!-- More Videos Section -->
    {
      moreVideos.length > 0 && (
        <section>
          <div class="flex justify-end mt-2">
            <button
              id="showMoreBtn"
              class="text-sm font-medium text-strong hover:underline"
            >
              More Videos
            </button>
          </div>

          <div id="moreVideosSection" class="hidden mt-6">
            <h2 class="text-2xl font-semibold mb-4">More Videos</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {moreVideos.map((video) => <VideoCard video={video} />)}
            </div>
          </div>
        </section>
      )
    }

    <!-- Other Media Section -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Other Media Mentions</h2>

      <div class="space-y-6">
        {
          otherMediaGrouped.map((group) => (
            <div>
              <h3 class="text-lg font-semibold text-strong mb-2">
                {group.source}
              </h3>

              <ul class="space-y-1">
                {group.items.map((item) => (
                  <li>
                    <Link
                      href={item.url}
                      newTab
                      class="underline text-base font-semibold"
                    >
                      {item.title}
                    </Link>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

  </PageSection>

</MainLayout>

<script type="module" src="src/scripts/embla.js"></script>

<script>
  const btn = document.getElementById('showMoreBtn');
  const section = document.getElementById('moreVideosSection');

  if (btn && section) {
    btn.addEventListener('click', () => {
      section.classList.remove('hidden');
      btn.style.display = 'none';
      section.scrollIntoView({ behavior: 'smooth' });
    });
  }
</script>