---
import MainLayout from "../layouts/mainLayout.astro";
import VideoCard from "../components/videoCard.astro";
import Link from "../components/link.astro";
import Heading from "../components/pageHeading.astro";
import PageSection from "../components/pageSection.astro";
import Button from "../components/button.astro";
import Card from "../components/card.astro";

import media from "../data/media.json";

const featuredVideos = media.featuredVideos;
const moreVideos = media.moreVideos;
const otherMedia = media.otherMedia;
---

<MainLayout>
  <PageSection class="space-y-4">
    <Heading level="h1" size="xl"> Media </Heading>

    <!-- Featured Videos Section -->
    <section>
      <Heading level="h2" size="lg"> Featured Videos </Heading>

      <div class="relative">
        <div class="embla overflow-hidden">
          <div class="embla__container flex gap-4 m-4">
            {
              featuredVideos.map((video) => (
                <div class="embla__slide embla-slide flex-[0_0_85%] sm:flex-[0_0_75%] md:flex-[0_0_65%] lg:flex-[0_0_55%]">
                  <VideoCard video={video} />
                </div>
              ))
            }
          </div>
        </div>

        <!-- Carousel Controls -->
        <Button id="prevBtn" variant="ghost" class="carousel-btn left-4"
          >&#8249;</Button
        >
        <Button id="nextBtn" variant="ghost" class="carousel-btn right-4"
          >&#8250;</Button
        >
      </div>
    </section>

    <!-- More Videos Section -->
    {
      moreVideos.length > 0 && (
        <section class="mt-4">
          <div class="flex justify-end">
            <Button id="showMoreBtn" variant="primary">
              More Videos
            </Button>
          </div>

          <div id="moreVideosSection" class="hidden">
            <Heading level="h2" size="lg">
              More Videos
            </Heading>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
              {moreVideos.map((video) => (
                <VideoCard video={video} />
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Other Media Section -->
    <section class="mt-6">
      <Heading level="h2" size="lg"> Other Media Mentions </Heading>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
        {
          otherMedia.map((item) => (
            <Card class="group transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
              <Link class="block group"
                href={item.url}
                newTab>
                <div class="mb-2 inline-flex rounded-full bg-[var(--color-accent)]/50 px-3 py-1 text-xs font-semibold">
                  {item.source}
                </div>

                <Heading level="h3" size="sm"> {item.title} </Heading>

                <div class="flex items-center text-sm text-neutral-500">
                  Read article
                  <span class="ml-2 transition-transform duration-300 group-hover:translate-x-1">
                    &rarr;
                  </span>
                </div>
              </Link>
            </Card>
          ))
        }
      </div>
    </section>
  </PageSection>
</MainLayout>

<script type="module" src="src/scripts/embla.js"></script>

<script>
  const btn = document.getElementById("showMoreBtn");
  const section = document.getElementById("moreVideosSection");

  if (btn && section) {
    btn.addEventListener("click", () => {
      section.classList.remove("hidden");
      btn.style.display = "none";
      section.scrollIntoView({ behavior: "smooth" });
    });
  }
</script>
