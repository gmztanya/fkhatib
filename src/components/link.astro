---
const base = import.meta.env.BASE_URL;

const {
  href,
  newTab = false,
  variant = "",
  class: className = ""
} = Astro.props;

const variants: any = {
  primary: "link link-primary",
  muted: "link link-muted",
  nav: "link link-nav"
};

const isExternal =
  href.startsWith("http") ||
  href.startsWith("mailto:") ||
  href.startsWith("tel:");

const finalHref = isExternal
  ? href
  : `${base}/${href.replace(/^\/+/, "")}`;

const styles = `${variants[variant] ?? ""} ${className}`;
---

<a
  href={finalHref}
  class={styles}
  target={newTab ? "_blank" : undefined}
  rel={newTab ? "noopener noreferrer" : undefined}
>
  <slot />
</a>