---
import Link from "./link.astro";
import Button from "./button.astro";
import Card from "./card.astro";

const { publication } = Astro.props;

const { title, authors, journal, year, doi, pdf } = publication;
---

<Card class="">
  <!-- Top Meta Data -->
  <p class="text-sm text-muted mb-2">
    {year} · {journal}
  </p>

  <!-- Title -->
  <h3 class="text-lg font-semibold text-strong mb-2">
    {title}
  </h3>

  <!-- Authors -->
  <p class="text-sm italic text-strong mb-3 line-clamp-2">
    {authors.join(", ")}
  </p>

  <!-- Doi (Only if exists and not N/A) -->
  {
    doi && doi.toLowerCase() !== "n/a" && (
      <Link href={doi} external newTab variant="muted" class="mb-3 block">
        {doi.replace("https://", "")}
      </Link>
    )
  }

  <!-- Actions -->
  <div class="flex gap-3 mt-3 flex-wrap">
    <Button
      data-citation={`${authors.join(", ")}. ${title}. ${journal} (${year})${
        doi && doi.toLowerCase() !== "n/a" ? ` ${doi}` : ""
      }`}
    >
      Copy Citation
    </Button>

    {
      pdf && (
        <Link href={pdf} external newTab>
          <Button variant="secondary"> View PDF </Button>
        </Link>
      )
    }
  </div>
</Card>
