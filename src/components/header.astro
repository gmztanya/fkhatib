---
import Link from "./link.astro";
import Button from "./button.astro";

const navLinks = [
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/media", label: "Media" },
  { href: "/contact", label: "Contact" },
  { href: "/cv", label: "CV" },
  { href: "/internships", label: "Internships" },
];
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath.includes(path);
---

<header class="header-bg text-white px-6 py-6 sm:px-20 sm:py-8 sticky top-0 z-50 shadow-md">
  <div class="flex items-center justify-between max-w-6xl mx-auto">
    <!-- Logo -->
    <Link href="/" class="flex items-center gap-4 cursor-pointer" variant="nav">
      
      <h1 class="text-xl font-semibold whitespace-nowrap">Khatib Lab</h1>

      <!-- Department section (hidden on mobile and tabs) -->
      <div class="hidden xl:flex items-center gap-4">
        <!-- Divider -->
        <div class="w-px h-10 bg-white/30"></div>

        <!-- Department text -->
        <div class="text-xs flex flex-col gap-1">
          <p>Department of Computer and Information Science</p>
          <p>University of Massachusetts Dartmouth</p>
        </div>
      </div>
    </Link>

    <!-- Desktop navigation -->
    <nav class="hidden desktop:flex gap-8 items-center text-white text-md">
      {
        navLinks.map((link) => (
          <Link
            href={link.href}
            class={`nav-link ${isActive(link.href) ? "nav-active" : ""}`}
            variant="nav"
          >
            {link.label}
          </Link>
        ))
      }
    </nav>

    <!-- Hamburger -->
    <Button
      id="menu-btn"
      variant="hamburger"
      class="desktop:hidden"
    />
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden flex-col gap-4 mt-4 desktop:hidden">
    {
      navLinks.map((link) => (
        <Link href={link.href} class="nav-link block" variant="nav">
          {link.label}
        </Link>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    btn.classList.toggle("open");
    menu?.classList.toggle("hidden");
  });
</script>
