---
const {
  level = "h1",       // h1, h2, h3...
  size = "xl",        // xl | lg | md | sm
  class: className = "",
} = Astro.props;

const Tag = level;

const sizes: any = {
  xl: "text-3xl md:text-4xl font-bold mb-4",
  lg: "text-xl md:text-2xl font-semibold leading-tight mb-3",
  md: "text-lg md:text-xl font-semibold leading-snug mb-2",
  sm: "text-base font-semibold leading-snug mb-1"
};

const styles = `${sizes[size]} ${className}`;
---

<Tag class={styles}>
  <slot />
</Tag>